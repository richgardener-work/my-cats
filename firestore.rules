rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    match /allowedEmails/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /cats/{catId} {
      allow read: if resource.data.isPublic == true || isAllowed();
      allow write: if isAllowed();
    }

    match /photos/{photoId} {
      allow read: if resource.data.isPublic == true || isAllowed();
      allow write: if isAllowed();
    }

    match /scores/{scoreId} {
      allow read: if isAllowed();
      allow write: if isAllowed() && request.auth.uid == resource.data.userId;
      allow create: if isAllowed();
    }
  }
}
